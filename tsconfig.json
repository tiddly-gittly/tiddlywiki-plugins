{
  "extends": "@modern-js/tsconfig/base.json",
  "compilerOptions": {
    "declaration": false,
    "jsx": "react-jsx",
    "noEmit": true,
    "typeRoots": [
      "node_modules/@types",
      "node_modules/tw5-typed"
    ],
    "lib": [
      "DOM",
      "ESNext"
    ],
    "baseUrl": "./"
  },
  "include": [
    "src",
    "*.json",
    "wiki/*.info",
    "*.mjs",
    "*.js",
    "src/**/*.d.ts"
  ]
}